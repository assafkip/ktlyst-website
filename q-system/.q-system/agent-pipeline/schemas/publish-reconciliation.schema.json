{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Publish Reconciliation",
  "description": "Phase 3 reconciliation of published posts vs drafted content",
  "type": "object",
  "required": ["date", "reconciled", "cadence_update"],
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "reconciled": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "post_url"],
        "properties": {
          "platform": { "type": "string" },
          "post_url": { "type": "string" },
          "post_preview": { "type": "string" },
          "matched_draft": { "type": ["string", "null"] },
          "match_score": { "type": "number" },
          "publish_date": { "type": "string" },
          "out_of_system": { "type": "boolean" }
        }
      }
    },
    "cadence_update": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "published_this_week": { "type": "integer" },
          "target": { "type": "integer" }
        }
      }
    },
    "notion_updates_needed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "page_id": { "type": "string" },
          "new_status": { "type": "string" },
          "post_url": { "type": "string" }
        }
      }
    }
  }
}
