{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Client Deliverables",
  "description": "Phase 6 client commitment check for overdue and upcoming deliverables",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "all_clear"],
  "properties": {
    "bus_version": { "type": "integer", "const": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generated_by": { "type": "string" },
    "overdue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["client", "deliverable", "due_date", "days_overdue"],
        "properties": {
          "client": { "type": "string" },
          "deliverable": { "type": "string" },
          "due_date": { "type": "string" },
          "days_overdue": { "type": "integer" },
          "status": { "type": "string" }
        }
      }
    },
    "due_today": { "type": "array" },
    "due_48h": { "type": "array" },
    "new_commitments": { "type": "array" },
    "all_clear": { "type": "boolean" }
  }
}
