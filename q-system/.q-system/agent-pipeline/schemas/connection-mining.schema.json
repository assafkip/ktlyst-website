{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Connection Mining",
  "description": "Phase 5 LinkedIn connection scan for ICP matches",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "matches"],
  "properties": {
    "bus_version": { "type": "integer", "const": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generated_by": { "type": "string" },
    "search_focus": { "type": "string" },
    "connections_scanned": { "type": "integer" },
    "connections_filtered_out": { "type": "integer" },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "profile_url", "score", "approach"],
        "properties": {
          "name": { "type": "string" },
          "headline": { "type": "string" },
          "company": { "type": "string" },
          "profile_url": { "type": "string" },
          "score": { "type": "integer" },
          "why_match": { "type": "string" },
          "draft_dm": { "type": "string" },
          "approach": { "type": "string", "enum": ["DM", "comment-first", "skip"] }
        }
      }
    }
  }
}
