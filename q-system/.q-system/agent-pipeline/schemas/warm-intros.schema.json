{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Warm Intro Match",
  "description": "Phase 2 warm introduction path matching for pipeline contacts",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "summary", "matches"],
  "properties": {
    "bus_version": { "type": "integer", "const": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generated_by": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["confirmed_warm", "unconfirmed_warm", "cold_only"],
      "properties": {
        "confirmed_warm": { "type": "integer" },
        "unconfirmed_warm": { "type": "integer" },
        "cold_only": { "type": "integer" }
      }
    },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_name", "target_firm", "match_status"],
        "properties": {
          "target_name": { "type": "string" },
          "target_firm": { "type": "string" },
          "target_tier": { "type": "string" },
          "warm_intro_path": { "type": "string" },
          "connector_found": { "type": "boolean" },
          "connector_name": { "type": "string" },
          "connector_last_contact": { "type": "string" },
          "connector_stage": { "type": "string" },
          "match_status": { "type": "string", "enum": ["confirmed", "unconfirmed", "cold_outreach_only"] }
        }
      }
    }
  }
}
