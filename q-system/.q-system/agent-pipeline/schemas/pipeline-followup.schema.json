{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pipeline Follow-up",
  "description": "Phase 5 follow-up actions for pipeline contacts",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "followups"],
  "properties": {
    "bus_version": { "type": "integer", "const": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generated_by": { "type": "string" },
    "followups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "platform", "message"],
        "properties": {
          "name": { "type": "string" },
          "company": { "type": "string" },
          "role": { "type": "string" },
          "days_since_last_contact": { "type": "integer" },
          "current_status": { "type": "string" },
          "platform": { "type": "string" },
          "message": { "type": "string" },
          "hook": { "type": "string" },
          "stage_advancement": {
            "type": ["object", "null"],
            "properties": {
              "from_stage": { "type": "string" },
              "to_stage": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "stage_changes": { "type": "array" },
    "stalled": { "type": "array" },
    "no_followups_needed": { "type": "boolean" }
  }
}
