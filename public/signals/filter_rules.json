{
  "metadata": {
    "description": "Pre-filter rules for Telegram message triage",
    "version": "2.0",
    "updated": "2026-02-22",
    "notes": "v2: Added threat-intel analytical rules for channels like SecAtor, PT SWARM, Group-IB, Ransomwatch"
  },
  "keyword_rules": [
    {
      "id": "stealer_tools",
      "category": "fraud",
      "tactic": "credential_theft",
      "keywords": ["redline", "raccoon", "vidar", "lumma", "stealc", "meta stealer", "aurora stealer"],
      "min_match": 1
    },
    {
      "id": "proxy_services",
      "category": "fraud",
      "tactic": "infrastructure",
      "keywords": ["residential proxy", "5g proxy", "mobile proxy", "911.re", "iproyal", "brightdata", "smartproxy", "oxylabs", "rotating proxy"],
      "min_match": 1
    },
    {
      "id": "antidetect",
      "category": "fraud",
