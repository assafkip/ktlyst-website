      "min_match": 1
    },
    {
      "id": "phishing_broader",
      "category": "security",
      "tactic": "phishing",
      "keywords": ["phishing", "spear-phishing", "spear phishing", "social engineering", "credential harvesting", "watering hole"],
      "min_match": 1
    },
    {
      "id": "dark_web_intel",
      "category": "security",
      "tactic": "data_leak",
      "keywords": ["dark web", "darknet", "underground forum", "initial access broker", "iab", "access for sale", "credentials for sale"],
      "min_match": 1
    },
    {
      "id": "threat_analysis_report",
      "category": "security",
      "tactic": "apt",
      "keywords": ["analysis", "report", "investigation", "attributed", "observed", "tracked", "uncovered"],
      "min_match": 2
    },
    {
      "id": "vulnerability_disclosure",
      "category": "security",
      "tactic": "exploitation",
      "keywords": ["disclosed", "patched", "fixed", "CVSS", "severity", "affected versions", "mitigation"],
      "min_match": 2
    }
  ],
  "regex_rules": [
    {
      "id": "cve_pattern",
      "category": "security",
      "tactic": "exploitation",
      "pattern": "CVE-\\d{4}-\\d{4,}"
    },
    {
      "id": "ip_address",
      "category": "ioc",
      "tactic": "infrastructure",
      "pattern": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b"
    },
    {
      "id": "btc_address",
      "category": "fraud",
      "tactic": "monetization",
      "pattern": "\\b[13][a-km-zA-HJ-NP-Z1-9]{25,34}\\b|\\bbc1[a-zA-HJ-NP-Z0-9]{39,59}\\b"
    },
    {
      "id": "onion_domain",
      "category": "security",
      "tactic": "infrastructure",
      "pattern": "[a-z2-7]{16,56}\\.onion"
    },
    {
      "id": "telegram_bot",
      "category": "ioc",
      "tactic": "infrastructure",
      "pattern": "@[A-Za-z0-9_]{5,}bot\\b"
    },
    {
      "id": "sha256_hash",
      "category": "ioc",
      "tactic": "infrastructure",
      "pattern": "\\b[a-fA-F0-9]{64}\\b"
    },
    {
      "id": "mitre_technique",
      "category": "security",
      "tactic": "apt",
      "pattern": "T\\d{4}(?:\\.\\d{3})?"
    }
  ],
  "skip_patterns": [
    "^\\s*\\+1\\s*$",
    "^\\s*\\U0001F44D",
    "^\\s*(yes|no|ok|thanks|thx|ty)\\s*$",
    "^\\s*https?://t\\.me/\\S+\\s*$"
  ]
}
