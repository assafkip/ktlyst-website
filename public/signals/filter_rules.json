    {
      "id": "threat_actor",
      "category": "security",
      "tactic": "apt",
      "keywords": ["apt28", "apt29", "lazarus", "fancy bear", "cozy bear", "sandworm", "turla", "kimsuky", "volt typhoon", "scattered spider"],
