    {
      "id": "threat_campaign",
      "category": "security",
      "tactic": "apt",
      "keywords": ["campaign", "targeted attack", "espionage", "cyber espionage", "cyberattack", "cyber attack", "attribution", "threat group", "threat actor", "nation-state", "state-sponsored"],
      "min_match": 1
