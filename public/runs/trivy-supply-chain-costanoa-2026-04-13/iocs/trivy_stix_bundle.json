      "name": "TeamPCP",
      "description": "Threat actor responsible for the Trivy supply chain compromise. Retained access from a prior Aqua Security incident. Used spoofed developer identities to push malicious commits. Expanded from binary compromise to GitHub Actions and npm ecosystem.",
      "threat_actor_types": ["criminal"],
      "aliases": ["TeamPCP"],
