// -----------------------------------------------------------------------------
// 4. systemd User Service Persistence (sysmon.py)
// MITRE: T1547.014 - Boot/Logon Autostart Execution (systemd)
// Tier 2 (detection-as-code): behavioral pattern
// -----------------------------------------------------------------------------
DeviceFileEvents
| where TimeGenerated > ago(30d)
| where FolderPath contains ".config/systemd/user" and FileName == "sysmon.py"
| summarize
    EventCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    Devices = make_set(DeviceName, 50),
    Users = make_set(InitiatingProcessAccountName, 50)
  by FolderPath, FileName
| extend Advisory = "Trivy/TeamPCP Supply Chain (March 2026)"
| extend PersistenceType = "systemd user service"
| extend C2Poll = "tdtqy-oyaaa-aaaae-af2dq-cai.raw.icp0.io every 5 min"
| project Devices, Users, FolderPath, FileName, EventCount, FirstSeen, LastSeen, Advisory, PersistenceType, C2Poll;

// Also check for systemctl commands enabling the persistence
DeviceProcessEvents
| where TimeGenerated > ago(30d)
| where ProcessCommandLine has_all ("systemctl", "--user") and ProcessCommandLine has "sysmon"
| summarize
    EventCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    Devices = make_set(DeviceName, 50),
    Users = make_set(AccountName, 50)
  by ProcessCommandLine
| extend Advisory = "Trivy/TeamPCP Supply Chain (March 2026)"
| project Devices, Users, ProcessCommandLine, EventCount, FirstSeen, LastSeen, Advisory;

// -----------------------------------------------------------------------------
// 5. /proc/*/mem Memory Scraping
// MITRE: T1005 - Data from Local System
// Tier 2 (detection-as-code): behavioral pattern
// -----------------------------------------------------------------------------
DeviceProcessEvents
| where TimeGenerated > ago(7d)
| where ProcessCommandLine matches regex @"/proc/\d+/mem"
| where InitiatingProcessFileName !in ("gdb", "strace", "valgrind", "lldb")
| summarize
    EventCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    Devices = make_set(DeviceName, 50),
    Users = make_set(AccountName, 50),
    Processes = make_set(FileName, 20)
  by InitiatingProcessFileName
| where EventCount > 3
| extend Advisory = "Trivy/TeamPCP Supply Chain (March 2026)"
| extend Technique = "Memory scraping via /proc/pid/mem for credential extraction"
| project Devices, Users, InitiatingProcessFileName, Processes, EventCount, FirstSeen, LastSeen, Advisory, Technique;

// -----------------------------------------------------------------------------
// 6. GitHub API - tpcp-docs Exfiltration Repo Creation
// MITRE: T1041 - Exfiltration Over C2 Channel
// Tier 2 (detection-as-code): behavioral pattern
// -----------------------------------------------------------------------------
DeviceNetworkEvents
| where TimeGenerated > ago(30d)
| where RemoteUrl has "api.github.com" and RemoteUrl has "repos"
| join kind=inner (
    DeviceProcessEvents
    | where TimeGenerated > ago(30d)
    | where ProcessCommandLine has "tpcp-docs" or ProcessCommandLine has "tpcp"
) on DeviceId
| summarize
    EventCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    Devices = make_set(DeviceName, 50),
    Users = make_set(AccountName, 50)
  by RemoteUrl
| extend Advisory = "Trivy/TeamPCP Supply Chain (March 2026)"
| extend ExfilMethod = "GitHub repos named tpcp-docs store AES-256-CBC + RSA-4096 encrypted credential bundles (tpcp.tar.gz)"
| project Devices, Users, RemoteUrl, EventCount, FirstSeen, LastSeen, Advisory, ExfilMethod;
