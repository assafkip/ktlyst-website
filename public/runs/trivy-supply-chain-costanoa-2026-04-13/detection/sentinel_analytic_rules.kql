// -----------------------------------------------------------------------------
// 1. DNS Queries to TeamPCP C2 Domains
// MITRE: T1041 - Exfiltration Over C2 Channel
// Tier 1 (auto-deploy): IOC-based DNS block
// -----------------------------------------------------------------------------
let TeamPCP_C2_Domains = dynamic([
    "scan.aquasecurtiy.org",
    "tdtqy-oyaaa-aaaae-af2dq-cai.raw.icp0.io",
    "plug-tab-protective-relay.trycloudflare.com"
]);
DnsEvents
| where TimeGenerated > ago(7d)
| where Name has_any (TeamPCP_C2_Domains)
| summarize
    EventCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    SourceIPs = make_set(ClientIP, 50)
  by Name
| extend Advisory = "Trivy/TeamPCP Supply Chain (March 2026)"
| extend Severity = "Critical"
| project Name, SourceIPs, EventCount, FirstSeen, LastSeen, Advisory, Severity;

// -----------------------------------------------------------------------------
// 2. Outbound Traffic to TeamPCP IP Infrastructure
// MITRE: T1041 - Exfiltration Over C2 Channel
// Tier 1 (auto-deploy): IOC-based IP block
// -----------------------------------------------------------------------------
let TeamPCP_IPs = dynamic(["45.148.10.212"]);
DeviceNetworkEvents
| where TimeGenerated > ago(7d)
| where RemoteIP in (TeamPCP_IPs)
| summarize
    EventCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    SourceDevices = make_set(DeviceName, 50),
    DestPorts = make_set(RemotePort, 20)
  by RemoteIP
| extend Advisory = "Trivy/TeamPCP Supply Chain (March 2026)"
| extend ThreatActor = "TeamPCP"
| extend Hosting = "TECHOFF SRV LIMITED, Amsterdam"
| project RemoteIP, SourceDevices, DestPorts, EventCount, FirstSeen, LastSeen, Advisory, ThreatActor, Hosting;

