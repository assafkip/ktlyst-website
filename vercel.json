{
  "headers": [
    {
      "source": "/signals/(.*).json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "dp-demo.ktlystlabs.com" }],
      "destination": "/dp_demo/index.html"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "dp-demo.ktlystlabs.com" }],
      "destination": "/dp_demo/:path+"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "demo.ktlystlabs.com" }],
      "destination": "/demo/index.html"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "demo.ktlystlabs.com" }],
      "destination": "/demo/:path+"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "demo2.ktlystlabs.com" }],
      "destination": "/demo2/index.html"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "demo2.ktlystlabs.com" }],
      "destination": "/demo2/:path+"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "dataflow.ktlystlabs.com" }],
      "destination": "/data_flow/index.html"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "dataflow.ktlystlabs.com" }],
      "destination": "/data_flow/:path+"
    },
    {
      "source": "/signals",
      "destination": "/signals/index.html"
    },
    {
      "source": "/runs",
      "destination": "/runs/index.html"
    },
    {
      "source": "/runs/:id",
      "destination": "/runs/:id/index.html"
    },
    {
      "source": "/runs/:id/",
      "destination": "/runs/:id/index.html"
    },
    {
      "source": "/runs/:id/:path*",
      "destination": "/runs/:id/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
